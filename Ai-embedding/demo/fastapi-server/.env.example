# === Model ===
# Path to best_model.pt (auto-detected from result_baseline if not set)
# EMBEDDING_MODEL_PATH=/path/to/best_model.pt

# Feature preset: A (210dim, 3axes), B (140dim, 2axes), C (102dim, 2axes)
FEATURE_PRESET=B

# Temporal interpolation target frame count
SEQUENCE_LENGTH=128

# === Vector DB ===
# FAISS index path (built by build_index.py)
# FAISS_INDEX_PATH=./index/demo_kg.faiss

# === Dataset (for build_index.py) ===
# DATASET_PATH=../../dataset/aihub

# === Word mapping ===
# WORD_MAPPING_PATH=../../word_mapping.json

# === Server ===
HOST=0.0.0.0
PORT=8000
