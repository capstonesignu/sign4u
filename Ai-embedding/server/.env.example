# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_token_here
HF_REPO_ID=capstoneSign/ksl-models

# HF 레포 내 파일명 (경로: capstone/encoder/, capstone/db/)
ENCODER_FILENAME=encoder_varlen_best.pt
FAISS_FILENAME=recorded_only.faiss
FAISS_LABELS_FILENAME=recorded_only.faiss.labels.json

# ── Feature preset ────────────────────────────────────────────────────────────
# A=204dim/3axes  B=136dim/2axes  C=98dim/2axes
FEATURE_PRESET=B

# ── FAISS top-k per segment ───────────────────────────────────────────────────
TOP_K=5

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
